        }
      },
      "AccessResponse": {
        "type": "object",
        "required": [
          "status",
          "message",
          "expires_in"
        ],
        "properties": {
          "expires_in": {
            "type": "string",
            "example": "12h"
          },
          "message": {
            "type": "string",
            "example": "IP 192.168.1.5 has been whitelisted."
          },
          "status": {
            "type": "string",
            "example": "success"
          }
        }
      },
      "AccessStatusResponse": {
        "type": "object",
        "required": [
          "server",
          "ip",
          "is_active"
        ],
        "properties": {
          "expiration": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64",
            "example": 1735689600
          },
          "ip": {
            "type": "string",
            "example": "192.168.1.50"
          },
          "is_active": {
            "type": "boolean",
            "example": true
          },
          "server": {
            "type": "string",
            "example": "minecraft-survival"
          },
          "time_remaining": {
            "type": [
              "string",
              "null"
            ],
            "example": "2h 30m"
